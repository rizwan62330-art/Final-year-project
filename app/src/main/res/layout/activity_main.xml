<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    tools:context=".MainActivity">

    <ScrollView
        android:id="@+id/content_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════ HERO HEADER ══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/header_gradient"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:paddingTop="48dp"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SMART ENERGY"
                            android:textColor="@color/accent_cyan"
                            android:textSize="10sp"
                            android:letterSpacing="0.25"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dashboard"
                            android:textColor="@color/text_white"
                            android:textSize="30sp"
                            android:fontFamily="sans-serif-light" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/pill_live_bg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <TextView
                            android:id="@+id/tv_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● LIVE"
                            android:textColor="@color/accent_cyan"
                            android:textSize="10sp"
                            android:fontFamily="sans-serif-medium"
                            android:letterSpacing="0.1" />

                    </LinearLayout>

                </LinearLayout>

                <!-- History button row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="WelCome"
                        android:textColor="@color/text_muted"
                        android:textSize="12sp" />

                    <!-- History navigation button -->
                    <TextView
                        android:id="@+id/btn_history"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 History"
                        android:textColor="@color/accent_cyan"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:background="@drawable/pill_live_bg"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tv_last_updated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Awaiting data…"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

            </LinearLayout>

            <!-- ══════════ TOTAL SUMMARY BANNER ══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/card_surface"
                android:paddingStart="22dp" android:paddingEnd="22dp"
                android:paddingTop="16dp" android:paddingBottom="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TOTAL TODAY"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-medium" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="bottom">

                        <TextView
                            android:id="@+id/tv_total_units"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/accent_green"
                            android:textSize="32sp"
                            android:fontFamily="sans-serif-light"
                            tools:text="4.20" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" kWh"
                            android:textColor="@color/text_muted"
                            android:textSize="14sp"
                            android:paddingBottom="5dp" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DAILY LIMIT"
                        android:textColor="@color/text_dim"
                        android:textSize="10sp"
                        android:letterSpacing="0.2"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tv_units_limit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6.50 kWh"
                        android:textColor="@color/text_muted"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- ══════════ CARDS GRID ══════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp"
                android:paddingBottom="32dp">

                <!-- ─── SECTION LABEL: BULBS ─── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BULBS"
                    android:textColor="@color/accent_yellow"
                    android:textSize="10sp"
                    android:letterSpacing="0.25"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp"
                    android:layout_marginStart="4dp" />

                <!-- ─── BULBS ROW ─── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <!-- ══ BULB 1 CARD ══ -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_bulb1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/card_surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="14dp">

                            <!-- Title row + toggle button -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="💡 Bulb 1"
                                    android:textColor="@color/text_white"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium" />

                                <!-- ON/OFF TOGGLE BUTTON -->
                                <TextView
                                    android:id="@+id/btn_bulb1_toggle"
                                    android:layout_width="52dp"
                                    android:layout_height="28dp"
                                    android:gravity="center"
                                    android:text="OFF"
                                    android:textColor="@color/status_offline"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:letterSpacing="0.05"
                                    android:background="@drawable/btn_toggle_off"
                                    android:clickable="true"
                                    android:focusable="true" />

                            </LinearLayout>

                            <!-- Voltage -->
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Voltage" android:textColor="@color/text_dim"
                                android:textSize="10sp" android:layout_marginBottom="2dp" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="bottom">
                                <TextView android:id="@+id/tv_bulb1_voltage" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="--"
                                    android:textColor="@color/text_white" android:textSize="22sp"
                                    android:fontFamily="sans-serif-light" tools:text="220" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text=" V" android:textColor="@color/accent_yellow" android:textSize="11sp"
                                    android:paddingBottom="3dp" />
                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:background="@color/divider" android:layout_marginTop="8dp"
                                android:layout_marginBottom="8dp" />

                            <!-- Current -->
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Current" android:textColor="@color/text_dim"
                                android:textSize="10sp" android:layout_marginBottom="2dp" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="bottom">
                                <TextView android:id="@+id/tv_bulb1_current" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="--"
                                    android:textColor="@color/text_white" android:textSize="22sp"
                                    android:fontFamily="sans-serif-light" tools:text="0.5" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text=" A" android:textColor="@color/accent_cyan" android:textSize="11sp"
                                    android:paddingBottom="3dp" />
                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:background="@color/divider" android:layout_marginTop="8dp"
                                android:layout_marginBottom="8dp" />

                            <!-- Units -->
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Units" android:textColor="@color/text_dim"
                                android:textSize="10sp" android:layout_marginBottom="2dp" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="bottom">
                                <TextView android:id="@+id/tv_bulb1_units" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="--"
                                    android:textColor="@color/text_white" android:textSize="22sp"
                                    android:fontFamily="sans-serif-light" tools:text="0.12" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text=" kWh" android:textColor="@color/accent_green" android:textSize="11sp"
                                    android:paddingBottom="3dp" />
                            </LinearLayout>

                        </LinearLayout>
                        <View android:layout_width="4dp" android:layout_height="match_parent"
                            android:background="@color/accent_yellow" />
                    </androidx.cardview.widget.CardView>

                    <!-- ══ BULB 2 CARD ══ -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_bulb2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/card_surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="💡 Bulb 2"
                                    android:textColor="@color/text_white"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium" />

                                <TextView
                                    android:id="@+id/btn_bulb2_toggle"
                                    android:layout_width="52dp"
                                    android:layout_height="28dp"
                                    android:gravity="center"
                                    android:text="OFF"
                                    android:textColor="@color/status_offline"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:letterSpacing="0.05"
                                    android:background="@drawable/btn_toggle_off"
                                    android:clickable="true"
                                    android:focusable="true" />

                            </LinearLayout>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Voltage" android:textColor="@color/text_dim"
                                android:textSize="10sp" android:layout_marginBottom="2dp" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="bottom">
                                <TextView android:id="@+id/tv_bulb2_voltage" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="--"
                                    android:textColor="@color/text_white" android:textSize="22sp"
                                    android:fontFamily="sans-serif-light" tools:text="218" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text=" V" android:textColor="@color/accent_yellow" android:textSize="11sp"
                                    android:paddingBottom="3dp" />
                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:background="@color/divider" android:layout_marginTop="8dp"
                                android:layout_marginBottom="8dp" />

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Current" android:textColor="@color/text_dim"
                                android:textSize="10sp" android:layout_marginBottom="2dp" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="bottom">
                                <TextView android:id="@+id/tv_bulb2_current" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="--"
                                    android:textColor="@color/text_white" android:textSize="22sp"
                                    android:fontFamily="sans-serif-light" tools:text="0.5" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text=" A" android:textColor="@color/accent_cyan" android:textSize="11sp"
                                    android:paddingBottom="3dp" />
                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:background="@color/divider" android:layout_marginTop="8dp"
                                android:layout_marginBottom="8dp" />

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Units" android:textColor="@color/text_dim"
                                android:textSize="10sp" android:layout_marginBottom="2dp" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="bottom">
                                <TextView android:id="@+id/tv_bulb2_units" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="--"
                                    android:textColor="@color/text_white" android:textSize="22sp"
                                    android:fontFamily="sans-serif-light" tools:text="0.11" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text=" kWh" android:textColor="@color/accent_green" android:textSize="11sp"
                                    android:paddingBottom="3dp" />
                            </LinearLayout>

                        </LinearLayout>
                        <View android:layout_width="4dp" android:layout_height="match_parent"
                            android:background="@color/accent_yellow" />
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- ─── SECTION LABEL: FANS ─── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FANS"
                    android:textColor="@color/accent_cyan"
                    android:textSize="10sp"
                    android:letterSpacing="0.25"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp"
                    android:layout_marginStart="4dp" />

                <!-- ─── FANS ROW ─── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <!-- ══ FAN 1 CARD ══ -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_fan1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/card_surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="🌀 Fan 1"
                                    android:textColor="@color/text_white"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium" />

                                <TextView
                                    android:id="@+id/btn_fan1_toggle"
                                    android:layout_width="52dp"
                                    android:layout_height="28dp"
                                    android:gravity="center"
                                    android:text="OFF"
                                    android:textColor="@color/status_offline"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:letterSpacing="0.05"
                                    android:background="@drawable/btn_toggle_off"
                                    android:clickable="true"
                                    android:focusable="true" />

                            </LinearLayout>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Voltage" android:textColor="@color/text_dim"
                                android:textSize="10sp" android:layout_marginBottom="2dp" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="bottom">
                                <TextView android:id="@+id/tv_fan1_voltage" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="--"
                                    android:textColor="@color/text_white" android:textSize="22sp"
                                    android:fontFamily="sans-serif-light" tools:text="219" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text=" V" android:textColor="@color/accent_yellow" android:textSize="11sp"
                                    android:paddingBottom="3dp" />
                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:background="@color/divider" android:layout_marginTop="8dp"
                                android:layout_marginBottom="8dp" />

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Current" android:textColor="@color/text_dim"
                                android:textSize="10sp" android:layout_marginBottom="2dp" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="bottom">
                                <TextView android:id="@+id/tv_fan1_current" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="--"
                                    android:textColor="@color/text_white" android:textSize="22sp"
                                    android:fontFamily="sans-serif-light" tools:text="1.2" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text=" A" android:textColor="@color/accent_cyan" android:textSize="11sp"
                                    android:paddingBottom="3dp" />
                            </LinearLayout>

                            <View android:layout_width="match_parent" android:layout_height="1dp"
                                android:background="@color/divider" android:layout_marginTop="8dp"
                                android:layout_marginBottom="8dp" />

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Units" android:textColor="@color/text_dim"
                                android:textSize="10sp" android:layout_marginBottom="2dp" />
                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="bottom">
                                <TextView android:id="@+id/tv_fan1_units" android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" android:text="--"
                                    android:textColor="@color/text_white" android:textSize="22sp"
                                    android:fontFamily="sans-serif-light" tools:text="0.26" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text=" kWh" android:textColor="@color/accent_green" android:textSize="11sp"
                                    android:paddingBottom="3dp" />
                            </LinearLayout>

                        </LinearLayout>
                        <View android:layout_width="4dp" android:layout_height="match_parent"
                            android:background="@color/accent_cyan" />
                    </androidx.cardview.widget.CardView>

                    <!-- ══ FAN 2 CARD ══ -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/card_fan2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:foreground="?android:attr/selectableItemBackground"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/card_surface">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="16dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="16dp"
                            android:paddingBottom="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="🌀 Fan 2"
                                    android:textColor="@color/text_white"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium" />

                                <TextView
                                    android:id="@+id/btn_fan2_toggle"
                                    android:layout_width="52dp"
                                    android:layout_height="28dp"
                                    android:gravity="center"
                                    android:text="OFF"
                                    android:textColor="@color/status_offline"
                                    android:textSize="10sp"
                                    android:fontFamily="sans-serif-medium"
                                    android:letterSpacing="0.05"
                                    android:background="@drawable/btn_toggle_off"
